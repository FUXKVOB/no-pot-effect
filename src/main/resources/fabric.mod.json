{
	"schemaVersion": 1,
	"id": "no-pot-effect",
	"version": "${version}",
	"name": "No Pot Effect",
	"description": "Убирает растяжение экрана от зелий, тошноту (nausea) и тряску при ударах. Всё настраивается в config/no-pot-effect.json.",
	"authors": [
		"reqwai"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/no-pot-effect",
		"sources": "https://github.com/FUXKVOB/no-pot-effect"
	},
	"license": "MIT",
	"icon": "assets/no-pot-effect/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.reqwai.nopoteffect.NoPotEffect"
		],
		"client": [
			"com.reqwai.nopoteffect.client.NoPotEffectClient"
		]
	},
	"mixins": [
		"no-pot-effect.mixins.json",
		{
			"config": "no-pot-effect.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.14.0",
		"minecraft": "~1.21.11",
		"java": ">=21",
		"fabric-api": "*"
	}
}
